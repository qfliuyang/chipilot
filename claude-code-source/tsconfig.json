{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "types": ["node", "react"]
  },
  "include": [
    "components/Terminal/**/*.ts",
    "components/Terminal/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
