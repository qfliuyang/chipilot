{
  "name": "chipilot-cli",
  "version": "0.1.0",
  "description": "Agentic EDA design platform for chip designers",
  "type": "module",
  "bin": {
    "chipilot": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:tiered": "node tests/tiered-test-runner.ts",
    "test:tier1": "vitest run tests/tier1-unit",
    "test:tier2": "vitest run tests/tier2-component",
    "test:tier2.5": "npx tui-test tests/tier2.5-tui-test/tui.test.ts",
    "test:tier3": "vitest run tests/tier3-integration --config vitest.tiered.config.ts",
    "test:tier4": "vitest run tests/tier4-e2e --config vitest.tiered.config.ts",
    "lint": "eslint src"
  },
  "keywords": [
    "eda",
    "cli",
    "chip-design",
    "cadence",
    "synopsys",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@pinecone-database/pinecone": "^5.1.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.2.0-beta.12",
    "openai": "^4.89.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@microsoft/tui-test": "^0.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "eslint": "^9.22.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  }
}
