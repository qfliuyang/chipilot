{
  "name": "chipclaude",
  "version": "1.0.0",
  "description": "Claude Code with integrated terminal - based on claude-code source",
  "type": "module",
  "bin": {
    "claude-terminal": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node test-terminal.mjs"
  },
  "keywords": [
    "claude",
    "terminal",
    "ai",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "node-pty": "^1.2.0-beta.12",
    "xterm-addon-serialize": "^0.11.0",
    "xterm-headless": "^5.3.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
